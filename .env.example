# ─── Application ────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=change-me-in-production

# ─── Search ──────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=         # get from https://brave.com/search/api/

# ─── LLM (optional – used for enhanced prompt parsing) ───────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=none           # none | openai | anthropic
LLM_MODEL=gpt-4o-mini

# ─── Database ────────────────────────────────────────────────────────
STORAGE_BACKEND=memory       # memory | mongodb | sqlite
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=leadgen

# ─── Queue ───────────────────────────────────────────────────────────
QUEUE_BACKEND=memory         # memory | redis
REDIS_URL=redis://localhost:6379/0

# ─── Proxies (comma-separated list or empty for direct) ──────────────
PROXY_LIST=
PROXY_ROTATION=round_robin   # round_robin | random
PROXY_ENABLED=false

# ─── Scraping behaviour ──────────────────────────────────────────────
REQUEST_TIMEOUT=30           # seconds
MAX_RETRIES=3
RETRY_DELAY=2                # seconds between retries
RATE_LIMIT_RPS=2             # requests per second per domain
MAX_CONCURRENT_CRAWLS=10
USE_PLAYWRIGHT=true          # set false to skip JS rendering (faster)

# ─── SERP ────────────────────────────────────────────────────────────
SERP_RESULTS_PER_QUERY=10
MAX_SERP_QUERIES=5

# ─── Lead quality ────────────────────────────────────────────────────
MIN_LEAD_SCORE=20            # 0-100; leads below this are dropped
DEDUPE_THRESHOLD=0.85        # similarity ratio for duplicate detection

# ─── LinkedIn ────────────────────────────────────────────────────────────────
LINKEDIN_ENABLED=true
LINKEDIN_MAX_PER_JOB=5       # hard cap on company pages scraped per job
LINKEDIN_DELAY_MIN=5.0       # min seconds between LinkedIn requests
LINKEDIN_DELAY_MAX=10.0      # max seconds between LinkedIn requests
